{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "6750dap_debug",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/build/output/demo.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverPath": "${env:OPENOCD_PATH}/bin/openocd.exe",
            "gdbPath": "${env:GNURISCV_TOOLCHAIN_PATH}/bin/riscv32-unknown-elf-gdb.exe",
            "device": "HPM6750xVMx",
            "searchDir": [
                "${workspaceFolder}/openocd"
            ],
            "configFiles": [
                "${workspaceFolder}/openocd/cmsis_dap.cfg",
                "${workspaceFolder}/openocd/hpm6750-single-core.cfg",
                "${workspaceFolder}/openocd/hpm6750ecat.cfg"
            ],
            "interface": "jtag",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "killOpenOCDOnStop": true
        },
        {
            "name": "6e00dap_debug",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/build/output/demo.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverPath": "${env:OPENOCD_PATH}/bin/openocd.exe",
            "gdbPath": "${env:GNURISCV_TOOLCHAIN_PATH}/bin/riscv32-unknown-elf-gdb.exe",
            "device": "HPM6E00xVMx",
            "searchDir": [
                "${workspaceFolder}/openocd"
            ],
            "configFiles": [
                "${workspaceFolder}/openocd/cmsis_dap.cfg",
                "${workspaceFolder}/openocd/hpm6e80-single-core.cfg",
                "${workspaceFolder}/openocd/hpm6e00evk.cfg"
            ],
            "interface": "jtag",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "killOpenOCDOnStop": true
        },
        {
            "name": "jlink_debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/output/demo.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "jlink",
            "gdbPath": "${env:GNURISCV_TOOLCHAIN_PATH}/bin/riscv32-unknown-elf-gdb.exe",
            "device": "HPM6750xVMx",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "interface": "jtag"
        }
    ]
}
